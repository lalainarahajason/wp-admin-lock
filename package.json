{
  "name": "lebo-secu",
  "version": "1.0.0",
  "description": "Lebo Secu WordPress security plugin - Dev tooling",
  "private": true,
  "scripts": {
    "start": "wp-scripts start",
    "build": "wp-scripts build",
    "dev": "wp-env start",
    "test": "wp-env run tests-cli --env-cwd=/var/www/html/wp-content/plugins/lebo-secu composer run test",
    "lint:php": "wp-env run tests-cli --env-cwd=/var/www/html/wp-content/plugins/lebo-secu vendor/bin/phpcs --standard=phpcs.xml plugin/",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:clean": "wp-env clean"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@wordpress/env": "^10.0",
    "@wordpress/scripts": "^27.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^6.0.0",
    "@wordpress/components": "^27.0.0",
    "@wordpress/element": "^5.0.0",
    "@wordpress/i18n": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
