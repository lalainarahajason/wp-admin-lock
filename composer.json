{
    "name": "lalainarahajason/lebo-secu",
    "description": "Plugin WordPress de sécurité multi-sites — Lebo Secu",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcsstandards/phpcsutils": "^1.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "classmap": [
            "plugin/includes/"
        ]
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "cs": "phpcs --standard=phpcs.xml plugin/",
        "cbf": "phpcbf --standard=phpcs.xml plugin/"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
